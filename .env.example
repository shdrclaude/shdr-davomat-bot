# === Telegram ===
BOT_TOKEN=123456:ABC-DEF_your_bot_token_here

# === PostgreSQL (async) ===
# Lokal docker-compose uchun:
DATABASE_URL=postgresql+asyncpg://shdr:shdr@postgres:5432/shdr

# === Redis ===
REDIS_URL=redis://redis:6379/0

# === Super adminlar (vergul bilan telegram id) ===
# Bu id egalari birinchi bo'lib filial/adminni sozlashi mumkin
SUPER_ADMINS=

# === Xato loglari yuboriladigan chat (ixtiyoriy) ===
LOG_CHAT_ID=

# === Vaqt zonasi ===
TZ_NAME=Asia/Tashkent
